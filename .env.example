# =============================================================================
# KIRPI QMS+ - YENI KURULUM ENV ORNEGI
# =============================================================================
# Yeni bir uygulamada temel otomasyon anahtari KIRPI_APP_PREFIX'tir.
# Prefix; Compose proje adini, DB adini, session cookie adini, network ve
# volume adlarini otomatik uretir. Asagidaki turetilen degerleri yeni kurulumda
# tanimlamayin: DB_NAME, SESSION_COOKIE_NAME, COMPOSE_PROJECT_NAME,
# KIRPI_NETWORK_NAME ve KIRPI_*_VOLUME_NAME.

# -----------------------------------------------------------------------------
# 1. Uygulama Kimligi - Yeni kurulumda degistirilmesi gereken temel alanlar
# -----------------------------------------------------------------------------
KIRPI_APP_PREFIX=qms
APP_NAME="Kirpi QMS+"
BASE_URL=https://qms.kirpinetwork.com
DB_PASS=CHANGE_WITH_A_STRONG_PASSWORD

# -----------------------------------------------------------------------------
# 2. Uygulama Runtime
# -----------------------------------------------------------------------------
APP_VER=1.0.15
APP_ENV=production
APP_DEBUG=false
APP_TRUST_PROXY=true
APP_TIMEZONE=Europe/Istanbul
APP_LOCALE=tr
APP_DATE_FORMAT_SHORT=d.m.Y
APP_DATE_FORMAT_LONG="d.m.Y H:i"
APP_DEFAULT_ROUTE=dashboard/view

# -----------------------------------------------------------------------------
# 3. Session ve Guvenlik
# -----------------------------------------------------------------------------
# Session cookie adi prefix'ten otomatik uretilir:
# KIRPICORESESSID1015 gibi. Yalnizca ozel ihtiyacta override edin.
SESSION_COOKIE_DOMAIN=
SESSION_IDLE_TIMEOUT_SECONDS=7200
SESSION_ID_ROTATE_SECONDS=900
SECURITY_HEADERS_ENABLED=true
AUTH_LOGIN_COVER_IMAGE=

# -----------------------------------------------------------------------------
# 4. Veritabani
# -----------------------------------------------------------------------------
# Docker icinde DB_HOST=db, DB_PORT=3306 ve DB_NAME=KIRPI_APP_PREFIX otomatik.
# Yeni kurulumda DB_NAME tanimlamayin.
DB_USER=root
DB_CHARSET=utf8mb4
DB_SSL_MODE=DISABLED
AUTO_DB_INSTALL=true
AUTO_DB_ENSURE_MISSING=false
AUTO_DB_ENSURE_COLUMNS=true
AUTO_DB_ENSURE_INDEXES=true

# -----------------------------------------------------------------------------
# 5. Web Setup
# -----------------------------------------------------------------------------
# Production'da kapali tutun. Gecici olarak acarsaniz guclu SETUP_KEY kullanin.
AUTO_WEB_SETUP=false
SETUP_KEY=

# -----------------------------------------------------------------------------
# 6. Mail
# -----------------------------------------------------------------------------
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="Kirpi QMS+"

# -----------------------------------------------------------------------------
# 7. API
# -----------------------------------------------------------------------------
API_ENABLED=true
API_TOKEN_TTL_SECONDS=2592000
API_REQUEST_LOG_RETENTION_DAYS=90

# -----------------------------------------------------------------------------
# 8. Belgeler ve Backup
# -----------------------------------------------------------------------------
DOCUMENTS_MAX_UPLOAD_MB=25
BACKUP_RETENTION_COUNT=20
BACKUP_VERIFY_DRY_RUN=true
BACKUP_INCLUDE_SYSTEM_TABLES=false

# -----------------------------------------------------------------------------
# 9. Throttle / Rate Limit
# -----------------------------------------------------------------------------
THROTTLE_ENABLED=true
THROTTLE_LOGIN_LIMIT=5
THROTTLE_LOGIN_WINDOW=600
THROTTLE_LOGIN_BLOCK=900
THROTTLE_CRITICAL_LIMIT=10
THROTTLE_CRITICAL_WINDOW=60
THROTTLE_CRITICAL_BLOCK=120
THROTTLE_GLOBAL_POST_LIMIT=180
THROTTLE_GLOBAL_POST_WINDOW=60
THROTTLE_GLOBAL_POST_BLOCK=60
THROTTLE_API_LIMIT=120
THROTTLE_API_WINDOW=60
THROTTLE_API_BLOCK=120
THROTTLE_API_AUTH_LIMIT=10
THROTTLE_API_AUTH_WINDOW=300
THROTTLE_API_AUTH_BLOCK=600

# -----------------------------------------------------------------------------
# 10. Kirpi Intelligence
# -----------------------------------------------------------------------------
# Provider kullanimi icin global kill-switch. Provider secret'larini arayuzden
# secret ayari veya deploy ortami uzerinden tanimlayin.
AI_EXTERNAL_MODEL_RUNTIME_ENABLED=false
AI_SQL_EXPLAIN_ENABLED=false

# =============================================================================
# YALNIZCA YEREL DOCKER KULLANIMI
# =============================================================================
# Dokploy production ortaminda bu portlari tanimlamayin. Yerelde
# docker-compose.local.yml ile kullanilir.
# KIRPI_APP_HTTP_PORT=8080
# KIRPI_DB_HOST_PORT=3307

# =============================================================================
# YALNIZCA MEVCUT VERILI KURULUM GECISI / OZEL OVERRIDE
# =============================================================================
# Yeni kurulumda bu satirlari aktif etmeyin. Legacy volume tasirken gercek
# Docker kaynak adlarini yazarak mevcut veriyi koruyun.
# COMPOSE_PROJECT_NAME=qms
# SESSION_COOKIE_NAME=QMSSESSID
# DB_NAME=qms
# KIRPI_NETWORK_NAME=qms_network
# KIRPI_DB_VOLUME_NAME=legacy_mysql_volume
# KIRPI_UPLOADS_VOLUME_NAME=legacy_uploads_volume
# KIRPI_LOGS_VOLUME_NAME=legacy_logs_volume
